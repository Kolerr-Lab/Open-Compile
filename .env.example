# OpenCompile Environment Configuration

# ─── Cloud AI Providers ───────────────────────────────────────────────────────
# At least one cloud key OR OLLAMA_BASE_URL is required for real generation
OPENAI_API_KEY=your-openai-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here
GOOGLE_API_KEY=your-google-api-key-here

# ─── Local LLM (Ollama) ──────────────────────────────────────────────────────
# Run Ollama locally: https://ollama.com — then `ollama pull qwen2.5-coder:7b`
# Uncomment and set to enable local model participation in consensus
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5-coder:7b

# ─── Engine Settings ─────────────────────────────────────────────────────────
# Default orchestrator model (gpt-4o recommended for cost-effectiveness)
OPENCOMPILE_MODEL=gpt-4o

# Learning Engine (stores patterns from past generations)
ENABLE_LEARNING=true

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
CORS_ORIGIN=http://localhost:3000

# ─── Logging ─────────────────────────────────────────────────────────────────
VERBOSE=false
