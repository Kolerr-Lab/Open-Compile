# OpenCompile Environment Configuration

# AI Provider API Keys (only OPENAI_API_KEY is required for basic usage)
OPENAI_API_KEY=your-openai-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here
GOOGLE_API_KEY=your-google-api-key-here

# Default Model (gpt-4o is recommended for cost-effectiveness)
OPENCOMPILE_MODEL=gpt-4o

# Learning Engine
ENABLE_LEARNING=true

# Logging
VERBOSE=false
